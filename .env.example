APP_NAME="Plant Disease Detection API"
ENVIRONMENT=development
LOG_LEVEL=INFO
PLANT_MODEL_PATH=Model/plant_disease_model.h5
PLANT_CLASS_INDEX_PATH=Model/class_indices.json
UPLOAD_DIR=static/uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MAX_UPLOAD_MB=8
TOP_K_PREDICTIONS=3
RATE_LIMIT_PER_MINUTE=30
ENABLE_GRADCAM=true
ENABLE_DOCS=true
PREDICTION_CONFIDENCE_THRESHOLD=0.0
